flowchart LR
    A["浏览器访问域名"] --> B["DNS 找到服务器 IP"]
    B --> C["Nginx 接收 HTTPS 请求"]

    C --> D{"请求类型"}

    D --> E["页面请求"]
    E --> F["返回前端静态文件"]

    D --> G["API 请求"]
    G --> H["转发到 Spring Boot"]

    H --> I["查询或写入数据库"]
    H --> J["调用大模型"]
    H --> K["调用语音识别"]
    H --> L["调用飞书 MCP"]

    L --> M["写入飞书"]
