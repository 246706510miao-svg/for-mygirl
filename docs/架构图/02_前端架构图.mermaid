flowchart TB
    subgraph A["前端应用：TypeScript"]
        A1["用户端：iPhone 移动 Web 或 PWA"]
        A2["管理员端：PC Web"]
    end

    subgraph B["用户端能力"]
        B1["对话式记录界面"]
        B2["AI 草稿预览"]
        B3["写入前确认"]
        B4["最近记录查看"]
    end

    subgraph C["对话式记录界面内部"]
        C1["文本输入"]
        C2["语音录入"]
        C3["识别文本回填"]
        C4["继续修改草稿"]
    end

    subgraph D["管理员端能力"]
        D1["查看记录状态"]
        D2["配置每日内容"]
        D3["处理异常记录"]
        D4["管理用户端展示"]
    end

    A1 --> B1
    A1 --> B2
    A1 --> B3
    A1 --> B4

    B1 --> C1
    B1 --> C2
    C2 --> C3
    C3 --> C4
    C1 --> C4

    A2 --> D1
    A2 --> D2
    A2 --> D3
    A2 --> D4
