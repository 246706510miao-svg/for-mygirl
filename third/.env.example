# 设为 0 时只用 mock 飞书；设为 1 时只走真实飞书，缺配置会报错，不会回退到 mock。
THIRD_FEISHU_USE_REAL=0
THIRD_FEISHU_APP_ID=
THIRD_FEISHU_APP_SECRET=
THIRD_FEISHU_TENANT_ACCESS_TOKEN=
THIRD_FEISHU_APP_TOKEN=
THIRD_FEISHU_TABLE_ID=
THIRD_FEISHU_TABLE_NAME=项目记录
THIRD_FEISHU_VIEW_ID=
THIRD_FEISHU_USER_ID_TYPE=open_id
THIRD_FEISHU_FIELD_NAME_MAP={}

THIRD_WORKFLOWAGENT_USE_LLM=0
THIRD_WORKFLOWAGENT_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# OpenAI 出口代理只给 third 的 OpenAI 调用使用；留空时直连 OpenAI。
# 示例：http://user:password@jp.example.com:3128
THIRD_OPENAI_PROXY_URL=
THIRD_OPENAI_TIMEOUT_SECONDS=60
THIRD_OPENAI_MAX_RETRIES=2

# LLM 出口路由：auto 会先按探测缓存判断 OpenAI 代理链路；domestic 会强制跳过 OpenAI 主通道。
THIRD_LLM_ROUTE_MODE=auto
THIRD_LLM_FALLBACK_PROVIDERS=deepseek,minimax
THIRD_LLM_PROBE_ENABLED=1
THIRD_LLM_PROBE_TTL_SECONDS=60
THIRD_LLM_PROBE_SAMPLES=3
THIRD_LLM_PROBE_MIN_SUCCESSES=2
THIRD_LLM_UNHEALTHY_TTL_SECONDS=120

# 国内 provider 使用 OpenAI-compatible 接口；配置不完整时自动跳过。
THIRD_DEEPSEEK_API_KEY=
THIRD_DEEPSEEK_BASE_URL=
THIRD_DEEPSEEK_MODEL=
THIRD_DEEPSEEK_TIMEOUT_SECONDS=60
THIRD_DEEPSEEK_MAX_RETRIES=0
THIRD_MINIMAX_API_KEY=
THIRD_MINIMAX_BASE_URL=
THIRD_MINIMAX_MODEL=
THIRD_MINIMAX_TIMEOUT_SECONDS=60
THIRD_MINIMAX_MAX_RETRIES=0

THIRD_MYSQL_DSN=mysql+pymysql://third_user:third_password@127.0.0.1:3307/third_service
THIRD_TEST_MYSQL_DSN=mysql+pymysql://third_user:third_password@127.0.0.1:3307/third_test
THIRD_REDIS_URL=redis://127.0.0.1:6380/0
THIRD_WORKFLOW_QUEUE_NAME=third:workflow:queue
THIRD_WORKFLOW_CONSUMER_GROUP=third-workflow-workers
THIRD_WORKFLOW_CONSUMER_NAME=worker-1
THIRD_WORKFLOW_LOCK_TTL_SECONDS=300
THIRD_WORKFLOW_PENDING_IDLE_MS=60000
THIRD_WORKFLOW_MAX_DELIVERIES=5
THIRD_WORKFLOW_DEAD_LETTER_QUEUE_NAME=third:workflow:dead
THIRD_WORKFLOW_ARTIFACT_TTL_SECONDS=3600
THIRD_WORKFLOW_IDEMPOTENCY_TTL_SECONDS=604800
THIRD_FEISHU_FIELD_CACHE_TTL_SECONDS=1800
# Docker/API/worker 联调建议设为 0，避免 MySQL 或 Redis 未连接时静默退回进程内内存。
THIRD_ALLOW_IN_MEMORY_FALLBACK=0
# 本地调试台开关；服务器部署时建议设为 0。
THIRD_DEBUG_ENABLED=1
# workflow plan 和失败步骤日志开关；未配置时默认跟随 THIRD_DEBUG_ENABLED。
THIRD_WORKFLOW_DEBUG_LOG=1

LANGSMITH_TRACING=true
LANGSMITH_PROJECT=for-mygirl-third-service
LANGSMITH_API_KEY=
